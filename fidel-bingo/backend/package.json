{
  "name": "fidel-bingo-api",
  "version": "2.0.0",
  "description": "Fidel Bingo Enterprise API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --skipLibCheck",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn src/server.ts",
    "test": "jest --runInBand",
    "lint": "eslint src/**/*.ts",
    "migrate": "typeorm migration:run -d src/config/database.ts",
    "create:admin": "ts-node -r tsconfig-paths/register src/scripts/createAdmin.ts",
    "seed:cartelas": "ts-node src/scripts/seedCartelas.ts"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.7.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.4.5",
    "@types/uuid": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^4.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^6.9.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.1",
    "pg": "^8.11.0",
    "prom-client": "^14.2.0",
    "redis": "^4.6.7",
    "socket.io": "^4.6.1",
    "stripe": "^13.3.0",
    "typeorm": "^0.3.17",
    "typescript": "^5.1.6",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.3",
    "@types/supertest": "^2.0.12",
    "jest": "^29.6.2",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0"
  }
}
